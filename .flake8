[flake8]
max-line-length = 120
exclude =
    .git,
    .venv,
    __pycache__,
    node_modules,
    dashboard/dist,
    dashboard/node_modules
extend-ignore =
    E127,
    E128,
    E202,
    E203,
    E221,
    E226,
    E231,
    E241,
    E261,
    E301,
    E302,
    E303,
    E304,
    E305,
    E306,
    E401,
    E402,
    E501,
    E701,
    E702,
    E741,
    F401,
    F541,
    F841,
    W291,
    W293,
    W391,
    W503
